{
  "metadata": [
    {
      "src": [
        {
          "files": ["**/*.csproj"],
          "exclude": ["**/bin/**", "**/obj/**", "**/test/**"]
        }
      ],
      "dest": "api"
    }
  ],
  "build": {
    "content": [
      {
        "files": ["api/**.yml", "api/index.md"]
      },
      {
        "files": ["index.md", "toc.yml"]
      },
      {
        "files": ["articles/**.md"]
      }
    ],
    "dest": ".",
    "output": "_site",
    "template": ["modern"],
    "globalMetadata": {
      "_appTitle": "EBCEYS.Infrastructure",
      "_enableSearch": true,
      "_appFooter": "Released under THE BEER-WARE LICENSE"
    }
  }
}