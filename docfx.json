{
  "metadata": [
    {
      "src": [
        {
          "files": ["**/*.csproj"],
          "exclude": ["**/bin/**", "**/obj/**", "**/test/**"]
        }
      ],
      "dest": "api"
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "api/**.yml",
          "api/README.md"
        ]
      },
      {
        "files": [
          "README.md",
          "toc.yml"
        ]
      }
    ],
    "dest": "_site",
    "template": ["default", "modern"],
    "globalMetadata": {
      "_appTitle": "EBCEYS.Infrastructure",
      "_enableSearch": true,
      "pdf": false
    }
  }
}