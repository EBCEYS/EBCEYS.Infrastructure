{
  "ignore": ["node_modules", ".git", ".github", "docs"],
  "should_use_git_ignore": true,
  "arch_docs": {
    "host_documentation": true,
    "generate_pdf": false,
    "generate_md": false,
    "commit_output": {
      "commit_to_git": true,
      "branch": "main",
      "path": "docs"
    }
  },
  "analyze_repo": {
    "ignore": ["node_modules", ".git", ".github", "public", "dist", "docs*"]
  }
}