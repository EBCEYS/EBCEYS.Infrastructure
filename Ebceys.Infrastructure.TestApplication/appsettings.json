{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Verbose",
      "Override": {
        "Microsoft": "Warning",
        "System": "Information",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithProcessId",
      "WithThreadId"
    ],
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  },
  "Urls": "http://0.0.0.0:5033;http://0.0.0.0:8080",
  "ConnectionStrings": {
    "TestApplication": "User ID=admin;Password=admin;Host=localhost;Port=8082;Database=test-app;Max Auto Prepare=100"
  },
  "auth-service": {
    "ServiceUrl": "http://localhost:5067"
  },
  "rabbit": {
    "ConnectionString": "amqp://guest:guest@localhost:5672/",
    "ExName": "TestEx",
    "ExType": "Fanout",
    "QueueName": "TestQueue",
    "TimeoutCallback": "00:00:30",
    "ExNameCallback": "callback",
    "ExTypeCallback": "Fanout",
    "QueueNameCallback": "callback_q"
  }
}